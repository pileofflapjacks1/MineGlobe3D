{
  "name": "mineglobe-3d",
  "private": true,
  "version": "1.0.0",
  "description": "Interactive 3D globe explorer for NYSE-listed precious metals mining companies",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "cd server && bash ./run.sh",
    "dev:all": "npx concurrently -k -n web,api -c cyan,yellow \"npm run dev\" \"npm run dev:api\"",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/three": "^0.185.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "papaparse": "^5.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-globe.gl": "^2.38.0",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.9.2",
    "three": "^0.185.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
